# Normalize all text files to LF in the repo, regardless of OS.
# This silences "LF will be replaced by CRLF" warnings on Windows clones and keeps
# blame/diffs deterministic across contributors.
* text=auto eol=lf

# Treat known binaries as binary.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
