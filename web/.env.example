# --- PUBLIC (shipped to the browser) ---

# Address of the deployed TokenFactory on LitVM LiteForge testnet (chainId 4441).
NEXT_PUBLIC_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# Address of the deployed TokenComments contract.
NEXT_PUBLIC_COMMENTS_ADDRESS=0x0000000000000000000000000000000000000000

# Built-in DEX (LitPump fork of Uniswap V2). Wired to the factory at deploy time
# so graduating curves auto-seed liquidity. The router is also used by the
# in-app swap widget for graduated tokens.
NEXT_PUBLIC_DEX_ROUTER=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_DEX_FACTORY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_WLTC=0x0000000000000000000000000000000000000000

# WalletConnect project id (optional but recommended).
# Create one at https://cloud.walletconnect.com — must be a 32-char id.
NEXT_PUBLIC_WC_PROJECT_ID=

# --- SERVER ONLY (never exposed to the browser) ---

# Pinata JWT used by /api/pinata/upload to pin uploaded images to IPFS.
PINATA_JWT=
